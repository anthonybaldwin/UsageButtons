# Reference clones (not part of our source)
tmp/

# Working plans / scratch notes — keep out of the repo
plans/

# Dependencies
node_modules/
bun.lockb.bak

# Build outputs
dist/
build/
*.tsbuildinfo
*.bun-build
.*.bun-build
# The bin/ directory contains compiled plugin binaries (Windows
# .exe, macOS arm64 + x64 native binaries, and the arch-dispatch
# shell wrapper on Mac). All platform-specific, all reproducible
# from `bun run build:<target>`, so we don't track any of it.
io.github.anthonybaldwin.UsageButtons.sdPlugin/bin/
io.github.anthonybaldwin.UsageButtons.sdPlugin/logs/
io.github.anthonybaldwin.UsageButtons.sdPlugin/usage-buttons.exe

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Secrets / user config
.env
.env.local
plugin.exe
.claude/

# Chrome extension private key. The public half is committed in
# chrome-extension/manifest.json as the `key` field, which pins the
# deterministic extension ID. Private key is only needed for future
# Chrome Web Store uploads — keep it locally, never commit.
*.pem
chrome-extension-private.pem
