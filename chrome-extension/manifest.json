{
  "manifest_version": 3,
  "name": "Usage Buttons Helper",
  "short_name": "UsageButtons",
  "version": "0.6.0",
  "description": "Companion extension for the Usage Buttons Stream Deck plugin. Proxies a narrow allowlist of AI usage APIs (claude.ai, cursor.com, ollama.com, chatgpt.com) using your logged-in browser session — credentials stay in Chrome.",
  "author": "Anthony Baldwin",
  "minimum_chrome_version": "127",
  "key": "",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "permissions": [
    "nativeMessaging",
    "alarms"
  ],
  "host_permissions": [
    "*://*.claude.ai/*",
    "*://*.cursor.com/*",
    "*://*.ollama.com/*",
    "*://*.chatgpt.com/*"
  ]
}
