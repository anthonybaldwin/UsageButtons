{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "UUID": "com.baldwin.usage-buttons",
  "Name": "Usage Buttons",
  "Author": "Anthony Baldwin",
  "Description": "Live AI-coding-assistant usage stats (session %, weekly %, credits, resets) as Stream Deck buttons with fill-style icons.",
  "Version": "0.0.1.0",
  "Icon": "assets/plugin-icon",
  "Category": "Usage Buttons",
  "CategoryIcon": "assets/category-icon",
  "CodePath": "bin/plugin",
  "CodePathWin": "bin/plugin-win.exe",
  "CodePathMac": "bin/plugin-mac",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.5"
  },
  "OS": [
    { "Platform": "windows", "MinimumVersion": "10" },
    { "Platform": "mac", "MinimumVersion": "12" }
  ],
  "Actions": [
    {
      "UUID": "com.baldwin.usage-buttons.stat",
      "Name": "Usage Stat",
      "Tooltip": "Display one usage stat (session %, weekly %, credits, …) with a dynamic fill icon.",
      "Icon": "assets/action-stat",
      "PropertyInspectorPath": "ui/stat.html",
      "SupportedInMultiActions": false,
      "States": [
        {
          "Image": "assets/action-stat-key",
          "TitleAlignment": "middle",
          "FontSize": "10",
          "ShowTitle": false
        }
      ]
    }
  ]
}
