{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "UUID": "io.github.anthonybaldwin.UsageButtons",
  "Name": "Usage Buttons",
  "Author": "Anthony Baldwin",
  "Description": "Live AI-coding-assistant usage stats (session %, weekly %, credits, resets) as Stream Deck buttons with fill-style icons.",
  "Version": "0.7.0.0",
  "Icon": "assets/plugin-icon",
  "Category": "Usage Buttons",
  "CategoryIcon": "assets/category-icon",
  "CodePath": "bin/plugin",
  "CodePathWin": "bin/plugin-win.exe",
  "CodePathMac": "bin/plugin-mac",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.5"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    },
    {
      "Platform": "mac",
      "MinimumVersion": "12"
    }
  ],
  "Actions": [
    {
      "UUID": "io.github.anthonybaldwin.UsageButtons.claude",
      "Name": "Claude",
      "Tooltip": "Claude usage stats — session %, weekly %, Sonnet %, Opus %, Design, Routines, extras, costs.",
      "Icon": "assets/action-claude",
      "PropertyInspectorPath": "ui/stat.html",
      "SupportedInMultiActions": false,
      "UserTitleEnabled": true,
      "States": [
        {
          "Image": "assets/action-claude-key",
          "ShowTitle": false,
          "TitleAlignment": "top"
        }
      ]
    },
    {
      "UUID": "io.github.anthonybaldwin.UsageButtons.codex",
