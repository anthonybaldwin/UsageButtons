  "CodePath": "bin/plugin",
  "CodePathWin": "bin/plugin-win.exe",
  "CodePathMac": "bin/plugin-mac",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.5"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    },
    {
      "Platform": "mac",
      "MinimumVersion": "12"
    }
  ],
