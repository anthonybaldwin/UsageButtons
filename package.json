{
  "name": "usage-buttons",
  "version": "0.0.1",
  "private": true,
  "description": "Stream Deck plugin that shows AI-coding-assistant usage stats as live buttons.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthonybaldwin/usage-buttons.git"
  },
  "homepage": "https://anthonybaldwin.github.io/usage-buttons/",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun run scripts/build.ts",
    "build:win": "bun run scripts/build.ts win",
    "build:mac": "bun run scripts/build.ts mac",
    "install:dev": "bun run scripts/install-dev.ts",
    "sync:codexbar": "bash scripts/sync-codexbar.sh",
    "dev": "bun --watch src/plugin.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.2"
  }
}
